---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * GENERACIÓN DINÁMICA DE RUTAS:
 * Define qué IDs existen (astronomia, paleontologia, biologia).
 * Astro creará una página física para cada uno de estos automáticamente.
 */
export function getStaticPaths() {
  return [
    {
      params: { id: "astronomia" },
      props: { title: "Viaje Espacial", theme: "astronomia" },
    },
    {
      params: { id: "paleontologia" },
      props: { title: "Mundo Jurásico", theme: "paleontologia" },
    },
    {
      params: { id: "biologia" },
      props: { title: "Mundo Celular", theme: "biologia" },
    },
  ];
}

const { title, theme } = Astro.props;

/**
 * NODOS DEL CAMINO:
 * Define el progreso del niño.
 * - 'completed': Verde.
 * - 'current': Destacado (amarillo con bounce).
 * - 'locked': Gris/Bloqueado.
 */
const nodes = [
  { label: "1", status: "completed" },
  { label: "2", status: "current" },
  { label: "3", status: "locked" },
  { label: "4", status: "locked" },
  { label: "5", status: "locked" },
];

const themeClasses = {
  themeBg: `bg-${theme}-themeBg`,
  lineColor: `bg-${theme}-lineColor`,
  cardBorder: `border-${theme}-cardBorder`,
  btnColor: `bg-${theme}-btnColor`,
};
---

<BaseLayout title={title}>
  <main
    class={`min-h-[calc(100vh-112px)] ${themeClasses.themeBg} flex flex-col items-center justify-center p-8 overflow-hidden`}
  >
    <div class="mb-12 text-center">
      <h1
        class="text-6xl font-black text-white uppercase tracking-tighter drop-shadow-2xl"
      >
        {title}
      </h1>
      <p class="text-white/70 font-bold mt-2 tracking-widest">
        ¡SIGUE EL CAMINO PARA APRENDER!
      </p>
    </div>

    <!-- PATHWAY HORIZONTAL: 
         Usa 'overflow-x-auto' para que los niños puedan deslizar el camino 
         si hay muchos niveles.
    -->
    <div
      class="relative w-full max-w-6xl overflow-x-auto pb-12 pt-12 no-scrollbar"
    >
      <div class="flex items-center gap-24 px-20 min-w-max relative">
        <!-- Línea conectora de fondo -->
        <div
          class={`absolute top-1/2 left-0 w-full h-4 ${themeClasses.lineColor} -translate-y-1/2 rounded-full opacity-50`}
        >
        </div>

        {
          nodes.map((node) => (
            /* LÓGICA DE RENDERIZADO DE NODOS:
               Aplica estilos diferentes según el status. 
               'scale-125' hace que el nivel actual sea más grande.
            */
            <button class="group relative z-10">
              <div
                class={`
              w-24 h-24 rounded-full border-[6px] ${themeClasses.cardBorder} 
              flex items-center justify-center text-3xl font-black transition-all
              ${node.status === "completed" ? "bg-green-400 text-white" : ""}
              ${node.status === "current" ? `${themeClasses.btnColor} scale-125 shadow-[0_10px_0_0_rgba(0,0,0,0.3)]` : ""}
              ${node.status === "locked" ? "bg-gray-400 text-gray-600 grayscale" : ""}
              group-hover:-translate-y-2 cursor-pointer
            `}
              >
                {node.label}
              </div>
              {node.status === "current" && (
                <div class="absolute -top-12 left-1/2 -translate-x-1/2 bg-white px-4 py-1 rounded-full font-black text-xs uppercase animate-bounce border-2 border-black">
                  ¡Aquí!
                </div>
              )}
            </button>
          ))
        }
      </div>
    </div>

    <a
      href="/dashboard"
      class="mt-12 px-10 py-4 bg-white border-4 border-black rounded-2xl font-black uppercase hover:bg-gray-100 transition-all shadow-[8px_8px_0_0_rgba(0,0,0,1)]"
    >
      Volver al Mapa
    </a>
  </main>
</BaseLayout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
