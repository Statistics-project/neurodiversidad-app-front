---
// src/components/jupiterRotating.astro
interface Props {
  size?: string;
  className?: string;
}

const { size, className = "" } = Astro.props;
---

<div 
  class={`jupiter-container pointer-events-none select-none ${className}`} 
  style={size ? `width: ${size}; height: ${size};` : undefined}
>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    xmlns:xlink="http://www.w3.org/1999/xlink" 
    version="1.1" 
    viewBox="0 0 500 500"
    width="100%"
    height="100%"
    class="w-full h-full"
  >
    <defs>
      <clipPath id="jupiter-clip">
        <circle cx="250" cy="250" r="120"/>
      </clipPath>
      <!-- Recorte para la mitad delantera del anillo de Júpiter (solo la mitad inferior inclinada) -->
      <clipPath id="jupiter-front-ring-clip">
        <rect x="-100" y="250" width="700" height="400" transform="rotate(-12 250 250)" />
      </clipPath>
      <!-- Gradiente para el color del anillo de Júpiter (medio gris/marrón) -->
      <linearGradient id="jupiterRingGrad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(154, 139, 124, 0)" />
        <stop offset="15%" stop-color="rgba(124, 111, 100, 0.3)" />
        <stop offset="30%" stop-color="rgba(90, 77, 65, 0.65)" />
        <stop offset="50%" stop-color="rgba(58, 48, 40, 0.75)" />
        <stop offset="70%" stop-color="rgba(90, 77, 65, 0.65)" />
        <stop offset="85%" stop-color="rgba(124, 111, 100, 0.3)" />
        <stop offset="100%" stop-color="rgba(154, 139, 124, 0)" />
      </linearGradient>
      <!-- Sombreado radial de esfera para dar profundidad y volumen 3D -->
      <radialGradient id="jupiter-shading" cx="30%" cy="30%" r="70%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.35" />
        <stop offset="35%" stop-color="#ffffff" stop-opacity="0" />
        <stop offset="70%" stop-color="#000000" stop-opacity="0" />
        <stop offset="88%" stop-color="#000000" stop-opacity="0.45" />
        <stop offset="100%" stop-color="#000000" stop-opacity="0.75" />
      </radialGradient>
    </defs>

    <!-- ANILLO TRASERO (detrás del planeta) -->
    <ellipse cx="250" cy="250" rx="220" ry="38" fill="none" stroke="url(#jupiterRingGrad)" stroke-width="22" transform="rotate(-12 250 250)" opacity="0.5" />

    <!-- Capa de atmósfera/brillo externo de Júpiter -->
    <circle cx="250" cy="250" r="130" fill="#df8f56" opacity="0.6">
       <animate attributeName="r" calcMode="spline" keySplines="0.3 0 0.7 1;0.3 0 0.7 1"
                values="130;135;130" dur="5s" repeatCount="indefinite"/>
     </circle>
    
    <!-- Cuerpo base del planeta (crema/café claro de base) -->
    <circle cx="250" cy="250" r="120" fill="#ecd8ba"/>

    <!-- Bandas de gas rotatorias (con máscara para mantenerse dentro de la esfera) -->
    <g clip-path="url(#jupiter-clip)">
      <g>
        <g id="jupiter-bands">
          <!-- Bandas en tonos café cálido, ocre y crema estético (más marrón y contrastado) -->
          <rect y="40" x="-50" width="600" height="26" rx="10" ry="10" fill="#925d3c" opacity="0.9" />
          <rect y="74" x="-50" width="600" height="14" rx="5" ry="5" fill="#dfbd9b" opacity="0.95" />
          <rect y="96" x="-50" width="600" height="34" rx="12" ry="12" fill="#ac6e46" />
          <rect y="138" x="-50" width="600" height="18" rx="6" ry="6" fill="#844825" />
          <rect y="164" x="-50" width="600" height="42" rx="15" ry="15" fill="#f2e5d0" />
          <rect y="214" x="-50" width="600" height="28" rx="10" ry="10" fill="#bf774b" />
          <rect y="250" x="-50" width="600" height="20" rx="8" ry="8" fill="#5d3119" />
          <rect y="278" x="-50" width="600" height="34" rx="12" ry="12" fill="#dfbd9b" opacity="0.95" />
          <rect y="320" x="-50" width="600" height="16" rx="6" ry="6" fill="#ac6e46" />
          <rect y="344" x="-50" width="600" height="28" rx="10" ry="10" fill="#f2e5d0" />
          <rect y="380" x="-50" width="600" height="22" rx="8" ry="8" fill="#844825" opacity="0.9" />
        </g>
        <use transform="translate(600 0)" xlink:href="#jupiter-bands"/>
        <animateTransform attributeName="transform" attributeType="XML" type="translate"
                          from="0 0" to="-600 0" dur="30s" repeatCount="indefinite"/>
      </g>
      
      <!-- Tormentas y la Gran Mancha Roja -->
      <g>
        <g id="jupiter-storms">
          <!-- La Gran Mancha Roja (Gran tormenta ovalada de Júpiter - Coral / Salmón vivo) -->
          <ellipse cx="280" cy="230" rx="28" ry="17" fill="#c23f2f" />
          <ellipse cx="280" cy="230" rx="20" ry="11" fill="#f09665" />
          
          <!-- Manchas blancas de tormenta secundarias y detalles -->
          <circle cx="110" cy="112" r="7" fill="#ffffff" opacity="0.9" />
          <circle cx="410" cy="112" r="7" fill="#ffffff" opacity="0.9" />
          <circle cx="210" cy="296" r="9" fill="#ffffff" opacity="0.85" />
          <circle cx="510" cy="296" r="9" fill="#ffffff" opacity="0.85" />
          
          <ellipse cx="70" cy="184" rx="14" ry="7" fill="#ffebd4" opacity="0.9" />
          <ellipse cx="370" cy="184" rx="14" ry="7" fill="#ffebd4" opacity="0.9" />
          
          <circle cx="160" cy="336" r="6" fill="#ffffff" opacity="0.8" />
          <circle cx="460" cy="336" r="6" fill="#ffffff" opacity="0.8" />
        </g>
        <use transform="translate(300 0)" xlink:href="#jupiter-storms"/>
        <animateTransform attributeName="transform" attributeType="XML" type="translate"
                          from="0 0" to="-300 0" dur="15s" repeatCount="indefinite"/>
      </g>

      <!-- Máscara de sombreado de esfera 3D por encima de los gráficos en movimiento -->
      <circle cx="250" cy="250" r="120" fill="url(#jupiter-shading)" />
    </g>

    <!-- ANILLO DELANTERO (enfrente del planeta, recortado a la mitad inferior) -->
    <g clip-path="url(#jupiter-front-ring-clip)">
      <ellipse cx="250" cy="250" rx="220" ry="38" fill="none" stroke="url(#jupiterRingGrad)" stroke-width="22" transform="rotate(-12 250 250)" opacity="0.5" />
    </g>
  </svg>
</div>

<style>
  .jupiter-container {
    display: inline-block;
    position: relative;
    filter: drop-shadow(0 0 35px rgba(229, 134, 75, 0.45)) drop-shadow(0 0 70px rgba(191, 108, 53, 0.25));
  }
</style>
