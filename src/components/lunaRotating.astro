---
// src/components/lunaRotating.astro
interface Props {
  size?: string;
  className?: string;
}

const { size, className = "" } = Astro.props;
---

<div 
  class={`moon-container pointer-events-none select-none ${className}`} 
  style={size ? `width: ${size}; height: ${size};` : undefined}
>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    xmlns:xlink="http://www.w3.org/1999/xlink" 
    version="1.1" 
    viewBox="0 0 200 200"
    width="100%"
    height="100%"
    class="w-full h-full"
  >
    <defs>
      <clipPath id="moon-clip">
        <circle cx="100" cy="100" r="60"/>
      </clipPath>
      <!-- Sombreado 3D de volumen esférico lunar -->
      <radialGradient id="moon-shading" cx="30%" cy="30%" r="70%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.35" />
        <stop offset="40%" stop-color="#ffffff" stop-opacity="0" />
        <stop offset="70%" stop-color="#000000" stop-opacity="0" />
        <stop offset="90%" stop-color="#000000" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#000000" stop-opacity="0.55" />
      </radialGradient>
    </defs>

    <!-- Resplandor plateado externo de la Luna -->
    <circle cx="100" cy="100" r="64" fill="#cbd5e1" opacity="0.4">
       <animate attributeName="r" calcMode="spline" keySplines="0.3 0 0.7 1;0.3 0 0.7 1"
                values="64;67;64" dur="4s" repeatCount="indefinite"/>
     </circle>
    
    <!-- Base de la Luna (gris claro) -->
    <circle cx="100" cy="100" r="60" fill="#cbd5e1"/>

    <!-- Cráteres rotatorios (con máscara) -->
    <g clip-path="url(#moon-clip)">
      <g>
        <g id="moon-craters">
          <!-- Cráter grande 1 -->
          <circle cx="35" cy="55" r="11" fill="#94a3b8" opacity="0.8" />
          <circle cx="33" cy="55" r="7" fill="#64748b" opacity="0.75" />
          
          <!-- Cráter grande 2 -->
          <circle cx="85" cy="115" r="14" fill="#94a3b8" opacity="0.8" />
          <circle cx="82" cy="115" r="9" fill="#64748b" opacity="0.75" />
          
          <!-- Cráter mediano 3 -->
          <circle cx="120" cy="50" r="8" fill="#94a3b8" opacity="0.8" />
          <circle cx="118" cy="50" r="5" fill="#64748b" opacity="0.75" />

          <!-- Cráteres pequeños y detalles del relieve lunar -->
          <circle cx="70" cy="35" r="6" fill="#94a3b8" opacity="0.75" />
          <circle cx="155" cy="85" r="7" fill="#94a3b8" opacity="0.75" />
          <circle cx="115" cy="130" r="5" fill="#94a3b8" opacity="0.75" />
          <circle cx="28" cy="105" r="6" fill="#94a3b8" opacity="0.75" />
          <circle cx="145" cy="120" r="4" fill="#94a3b8" opacity="0.7" />
          
          <!-- Cráter grande en use offset -->
          <circle cx="180" cy="65" r="10" fill="#94a3b8" opacity="0.8" />
          <circle cx="178" cy="65" r="6" fill="#64748b" opacity="0.75" />
        </g>
        <use transform="translate(200 0)" xlink:href="#moon-craters"/>
        <animateTransform attributeName="transform" attributeType="XML" type="translate"
                          from="0 0" to="-200 0" dur="20s" repeatCount="indefinite"/>
      </g>

      <!-- Sombreado de volumen 3D -->
      <circle cx="100" cy="100" r="60" fill="url(#moon-shading)" />
    </g>
  </svg>
</div>

<style>
  .moon-container {
    display: inline-block;
    position: relative;
    filter: drop-shadow(0 0 25px rgba(203, 213, 225, 0.4)) drop-shadow(0 0 50px rgba(100, 116, 139, 0.2));
  }
</style>
