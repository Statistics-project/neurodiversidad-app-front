---
interface Props {
  title: string; // Título que se mostrará en la barra superior
  backHref?: string; // Ruta a la que regresará el botón de volver
  homeHref?: string; // Ruta a la que llevará el botón de inicio
  color?: string; // Puedes usar esto para personalizar el color de fondo o texto si quieres
}

// Le damos el morado por defecto si no le pasamos nada
const { title, backHref = "#", homeHref = "/", color = "bg-[#4f1d95]" } = Astro.props;
---

<header
  class={`absolute top-0 z-50 w-full ${color} px-4 py-5 shadow-[0_4px_16px_rgba(0,0,0,0.3)] md:px-8`}
>
  <div class="mx-auto grid max-w-2xl grid-cols-[64px_1fr_64px] justify-between items-center gap-4">
    <!-- Botón Atrás -->
    <a
      href={backHref}
      aria-label="Volver"
      class="group inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-white shadow-[0_6px_0_rgba(0,0,0,0.25)] transition-all duration-100 ease-out active:translate-y-1.25 active:shadow-[0_1px_0_rgba(0,0,0,0.25)]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-8 w-8 text-purple-800 transition-transform group-active:scale-90"
      >
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
    </a>

    <h1
      class="px-2 text-center text-lg font-extrabold uppercase tracking-wide text-white drop-shadow-md sm:text-2xl md:text-4xl"
    >
      {title}
    </h1>

    <!-- Botón Inicio -->
    <a
      href={homeHref}
      aria-label="Inicio"
      class="group inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-white shadow-[0_6px_0_rgba(0,0,0,0.25)] transition-all duration-100 ease-out active:translate-y-1.25 active:shadow-[0_1px_0_rgba(0,0,0,0.25)]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-8 w-8 text-purple-700 transition-transform group-active:scale-90"
      >
        <path
          d="M11.47 3.84a.75.75 0 0 1 1.06 0l8.69 8.69a.75.75 0 1 1-1.06 1.06l-.22-.22V19.5a1.5 1.5 0 0 1-1.5 1.5h-3a.75.75 0 0 1-.75-.75V16.5a.75.75 0 0 0-.75-.75h-2.5a.75.75 0 0 0-.75.75v3.75a.75.75 0 0 1-.75.75h-3a1.5 1.5 0 0 1-1.5-1.5v-6.13l-.22.22a.75.75 0 1 1-1.06-1.06l8.69-8.69Z"
        ></path>
      </svg>
    </a>
  </div>
</header>
