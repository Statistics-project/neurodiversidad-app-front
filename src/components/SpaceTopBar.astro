---
interface Props {
  title: string;
  backHref?: string;
  homeHref?: string;
}

const { title, backHref = "#", homeHref = "/" } = Astro.props;
---

<header
  class="fixed top-0 z-50 w-full bg-[#4f1d95] px-3 py-3 shadow-[0_4px_16px_rgba(0,0,0,0.3)] sm:px-4 md:px-6"
  style="background-color: #4f1d95 !important;"
>
  <div
    class="mx-auto grid w-full grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-2 sm:gap-4 md:gap-6"
  >
    <!-- Botón Atrás -->
    <a
      href={backHref}
      aria-label="Volver"
      class="group justify-self-start inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-white shadow-[0_8px_0_rgba(0,0,0,0.35)] transition-all duration-100 ease-out active:translate-y-[6px] active:shadow-[0_2px_0_rgba(0,0,0,0.35)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 text-purple-800 transition-transform group-active:scale-90">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
    </a>

    <h1
      class="px-2 text-center text-lg font-extrabold uppercase tracking-wide text-white drop-shadow-md sm:text-2xl md:text-4xl"
    >
      {title}
    </h1>

    <!-- Botón Inicio -->
    <a
      href={homeHref}
      aria-label="Inicio"
      class="group justify-self-end inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-white shadow-[0_8px_0_rgba(0,0,0,0.35)] transition-all duration-100 ease-out active:translate-y-[6px] active:shadow-[0_2px_0_rgba(0,0,0,0.35)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-8 w-8 text-purple-700 transition-transform group-active:scale-90">
        <path d="M11.47 3.84a.75.75 0 0 1 1.06 0l8.69 8.69a.75.75 0 1 1-1.06 1.06l-.22-.22V19.5a1.5 1.5 0 0 1-1.5 1.5h-3a.75.75 0 0 1-.75-.75V16.5a.75.75 0 0 0-.75-.75h-2.5a.75.75 0 0 0-.75.75v3.75a.75.75 0 0 1-.75.75h-3a1.5 1.5 0 0 1-1.5-1.5v-6.13l-.22.22a.75.75 0 1 1-1.06-1.06l8.69-8.69Z"></path>
      </svg>
    </a>
  </div>
</header>
