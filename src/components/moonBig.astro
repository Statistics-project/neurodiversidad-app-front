---
// src/components/moonBig.astro
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`moon-big-container pointer-events-none select-none ${className}`}>
  <div class="moon"></div>
  <div class="moon__crater moon__crater1"></div>
  <div class="moon__crater moon__crater2"></div>
  <div class="moon__crater moon__crater3"></div>
</div>

<style>
  .moon-big-container {
    position: absolute;
    top: -100px;
    left: -300px;
    width: 900px;
    height: 900px;
    z-index: 1;
  }

  .moon {
    background: linear-gradient(90deg, #d0d0d0 48%, #919191 100%);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 100%;
    box-shadow: 0px 0px 30px -4px rgba(0, 0, 0, 0.5);
  }

  .moon__crater {
    position: absolute;
    content: "";
    border-radius: 100%;
    background: linear-gradient(90deg, #7a7a7a 38%, #c3c3c3 100%);
    opacity: 0.6;
  }

  .moon__crater1 {
    top: 250px;
    left: 500px;
    width: 60px;
    height: 180px;
  }

  .moon__crater2 {
    top: 650px;
    left: 340px;
    width: 40px;
    height: 80px;
    transform: rotate(55deg);
  }

  .moon__crater3 {
    top: -20px;
    left: 40px;
    width: 65px;
    height: 120px;
    transform: rotate(250deg);
  }
</style>
