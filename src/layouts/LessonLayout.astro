---
// src/layouts/LessonLayout.astro
import { createIcons, X } from "lucide"; // Assuming 'X' for close button

interface Props {
  title?: string;
  progress?: number; // Progress from 0 to 100
}

const { title = "Lección", progress = 0 } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="font-sans min-h-screen bg-[#F8FAFC] text-[#0F172A]">
    <div class="relative w-full h-2 bg-gray-200">
      <div
        class="absolute top-0 left-0 h-full bg-blue-500 transition-all duration-300"
        style={`width: ${progress}%;`}
      >
      </div>
      <button
        class="absolute top-4 right-4 p-3 bg-white rounded-full shadow-md z-10"
      >
        <i data-lucide="x" class="w-6 h-6 text-gray-600"></i>
      </button>
    </div>
    <slot />
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      lucide.createIcons();
    </script>
  </body>
</html>
