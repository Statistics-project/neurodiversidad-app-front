---
// src/layouts/BaseLayout.astro
import { createIcons, Settings, User, Rocket, Bone, Microscope } from "lucide";

interface Props {
  title?: string;
}

const { title = "CapyLearn" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body
    class="bg-[#F8FAFC] font-sans selection:bg-[#FDE047] min-h-screen text-[#0F172A]"
  >
    <!-- HEADER GLOBAL: 'sticky top-0' lo mantiene siempre a la vista al hacer scroll -->
    <header
      class="flex items-center justify-between py-3 px-8 bg-white/90 backdrop-blur-md border-b-8 border-black sticky top-0 z-50 shadow-xl"
    >
      <div class="flex items-center gap-4">
        <!-- Logo: Añadido un ligero giro para que se vea más juguetón -->
        <div
          class="bg-[#FFD60A] border-4 border-black rounded-2xl px-6 py-2 font-black text-xl tracking-widest text-black uppercase shadow-[4px_4px_0_0_#000] -rotate-1 hover:rotate-0 transition-transform cursor-pointer"
        >
          CAPYLEARN
        </div>
      </div>

      <!-- Botones de Navegación de Perfil/Configuración -->
      <div class="flex gap-5">
        <button
          class="p-4 bg-white border-4 border-black rounded-2xl hover:-translate-y-1 hover:shadow-[6px_6px_0_0_#000] transition-all active:translate-y-1 active:shadow-none cursor-pointer"
        >
          <i data-lucide="user" class="w-8 h-8 text-black"></i>
        </button>
        <button
          class="p-4 bg-white border-4 border-black rounded-2xl hover:-translate-y-1 hover:shadow-[6px_6px_0_0_#000] transition-all active:translate-y-1 active:shadow-none cursor-pointer"
        >
          <i data-lucide="settings" class="w-8 h-8 text-black"></i>
        </button>
      </div>
    </header>

    <!-- El contenido de cada página se inserta aquí -->
    <slot />

    <!-- Inicialización de iconos Lucide: Necesario para que los iconos SVG se rendericen -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      lucide.createIcons();
    </script>
  </body>
</html>
