---
// src/layouts/BaseLayout.astro
interface Props {
  title?: string;
}

const { title = "CapyLearn" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      @import "../styles/global.css";
      
      /* Animación suave para la racha de fuego */
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-3px); }
      }
      .animate-float {
        animation: float 3s ease-in-out infinite;
      }
    </style>
    <!-- Lucide Icons -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
  </head>
  
  <body class="bg-[#0F172A] font-sans min-h-screen text-[#0F172A] m-0 p-0 overflow-hidden">
    
    {/* ================= HEADER FLOTANTE ================= */}
    <header class="fixed top-0 left-0 w-full z-100 p-4 md:p-8 flex items-start justify-between pointer-events-none">
      
      {/* LOGO (Izquierda) */}
<a href="/" class="pointer-events-auto group flex items-center gap-3 bg-[#FFD60A] border-4 border-black rounded-2xl px-4 md:px-6 py-2 md:py-3 shadow-[6px_6px_0_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_0_#000] active:translate-y-1 active:shadow-none transition-all cursor-pointer">
  
  {/* CAMBIO AQUÍ: Imagen del logo en lugar del icono */}
  <img 
    src="/favicon.svg" 
    alt="Logo CapyLearn" 
    class="w-8 h-8 md:w-10 md:h-10 object-contain group-hover"
  />
  
  <span class="font-black text-xl md:text-2xl tracking-widest text-black uppercase mt-1">
    CapyLearn
  </span>
</a>

      {/* ZONA DE USUARIO Y GAMIFICACIÓN (Derecha) */}
      <div class="pointer-events-auto flex items-center gap-3 md:gap-4">
        
        {/* Puntos / Estrellas (Oculto en móviles pequeños) */}
        <div class="hidden lg:flex items-center gap-2 bg-[#4CC9F0] border-4 border-black rounded-2xl px-4 py-2 shadow-[4px_4px_0_0_#000] cursor-help hover:-translate-y-1 transition-transform">
          <i data-lucide="star" class="w-6 h-6 text-black fill-[#FDE047]"></i>
          <span class="font-black text-lg text-black mt-1">1,250</span>
        </div>

        {/* Racha / Streak (Oculto en móviles pequeños) */}
        <div class="hidden md:flex items-center gap-2 bg-[#FF9F1C] border-4 border-black rounded-2xl px-4 py-2 shadow-[4px_4px_0_0_#000] cursor-help hover:-translate-y-1 transition-transform">
          <i data-lucide="flame" class="w-6 h-6 text-black fill-[#FFBF69] animate-float"></i>
          <span class="font-black text-lg text-black mt-1">14</span>
        </div>

        {/* Perfil de Usuario */}
        <button class="flex items-center gap-3 bg-white border-4 border-black rounded-2xl p-1 pr-4 md:p-2 md:pr-6 shadow-[6px_6px_0_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_0_#000] active:translate-y-1 active:shadow-none transition-all cursor-pointer">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl border-2 border-black bg-[#F72585] overflow-hidden flex items-center justify-center">
            {/* Avatar generado aleatoriamente para el diseño */}
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Nefer&backgroundColor=F72585" alt="Avatar" class="w-full h-full object-cover scale-110 translate-y-1" />
          </div>
          <span class="hidden sm:block font-black text-lg uppercase tracking-wide mt-1">Nefer</span>
          <i data-lucide="chevron-down" class="hidden sm:block w-5 h-5 text-black"></i>
        </button>

        {/* Botón de Ajustes (Solo icono en móvil, integrado en PC) */}
        <button class="bg-white border-4 border-black rounded-2xl p-3 md:p-4 shadow-[6px_6px_0_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_0_#000] active:translate-y-1 active:shadow-none transition-all flex items-center justify-center cursor-pointer group">
          <i data-lucide="menu" class="w-6 h-6 text-black block md:hidden"></i>
          <i data-lucide="settings" class="w-6 h-6 text-black hidden md:block group-hover:rotate-90 transition-transform duration-500"></i>
        </button>

      </div>
    </header>

    {/* ================= CONTENIDO PRINCIPAL (DASHBOARD) ================= */}
    <main class="relative w-full h-screen">
      <slot />
    </main>

    {/* ================= FOOTER FLOTANTE (CapyLabs) ================= */}
    <footer class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-100 pointer-events-none">
      <div class="pointer-events-auto group relative flex items-center gap-3 bg-white border-4 border-black rounded-2xl px-4 py-2 shadow-[6px_6px_0_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_0_#000] transition-all cursor-pointer">
        <span class="text-2xl md:text-3xl origin-bottom group-hover:rotate-12 transition-transform"></span>
        <div class="flex flex-col">
          <span class="font-black text-xs md:text-sm uppercase tracking-wider text-black leading-none mt-1">CapyLabs</span>
          <span class="font-bold text-[8px] md:text-[10px] text-gray-500 uppercase tracking-widest hidden md:block">ALL RIGHTS RESERVED 2026</span>
        </div>
      </div>
    </footer>

    {/* Inicializador de Iconos */}
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        if (window.lucide) {
          window.lucide.createIcons();
        }
      });
    </script>
  </body>
</html>