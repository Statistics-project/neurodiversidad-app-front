---
// src/layouts/SpaceLayout.astro
import "../styles/global.css";
import bgEspacioDesktop from "../assets/iconos-mapa-espacio/background3space.png";

interface Props {
  title: string;
  backHref?: string;
  homeHref?: string;
}

const { title, backHref = "/dashboard", homeHref = "/dashboard" } = Astro.props; // Los botones de navegación ahora apuntan por defecto al dashboard.
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Mapa de niveles</title>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
  </head>

  <body class="relative min-h-screen w-full bg-[#06041a] overflow-x-hidden selection:bg-[#FDE047]">
    
    <div
      class="fixed inset-0 z-0 bg-cover bg-center bg-no-repeat opacity-80 pointer-events-none"
      style={`background-image: url(${bgEspacioDesktop.src});`}
    />

    <header class="fixed top-0 left-0 w-full z-[100] p-4 md:p-6 flex items-start justify-between pointer-events-none">
      
      <div class="pointer-events-auto flex items-center gap-3">
        <a 
          href="/dashboard" 
          class="flex items-center justify-center w-12 h-12 md:w-14 md:h-14 bg-white border-4 border-black rounded-2xl shadow-[4px_4px_0_0_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0_0_#000] active:translate-y-1 active:shadow-none transition-all cursor-pointer"
          aria-label="Volver atrás"
        >
          <i data-lucide="arrow-left" class="w-6 h-6 md:w-8 md:h-8 text-black"></i>
        </a>
      </div>

      <div class="pointer-events-auto flex items-center gap-3">
        <div class="flex items-center gap-2 bg-[#FF9F1C] border-4 border-black rounded-2xl px-3 md:px-4 py-1.5 md:py-2 shadow-[4px_4px_0_0_#000]">
          <i data-lucide="flame" class="w-5 h-5 md:w-6 md:h-6 text-black fill-[#FFBF69] animate-pulse"></i>
          <span class="font-black text-sm md:text-lg text-black mt-1">14</span>
        </div>

        <button class="hidden sm:flex items-center gap-2 bg-white border-4 border-black rounded-2xl p-1 pr-4 shadow-[4px_4px_0_0_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0_0_#000] active:translate-y-1 active:shadow-none transition-all cursor-pointer">
          <div class="w-8 h-8 md:w-10 md:h-10 rounded-xl border-2 border-black bg-[#F72585] overflow-hidden flex items-center justify-center">
             <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Nefer&backgroundColor=F72585" alt="Avatar" class="w-full h-full object-cover scale-110 translate-y-1" />
          </div>
          <span class="font-black text-sm md:text-base uppercase tracking-wide mt-1">Nefer</span>
        </button>
      </div>
    </header>

    <main class="relative w-full min-h-screen m-0 p-0 bg-transparent">
      <slot />
    </main>

    <nav class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] pointer-events-none">
      <div class="pointer-events-auto flex gap-4 bg-white/90 backdrop-blur-md border-4 border-black rounded-3xl p-2 shadow-[6px_6px_0_0_#000]">
        <a href="/dashboard" class="flex items-center justify-center w-12 h-12 md:w-14 md:h-14 bg-white border-2 border-black rounded-2xl hover:bg-gray-100 active:scale-95 transition-all">
          <i data-lucide="home" class="w-6 h-6 text-black"></i>
        </a>
        <button class="flex items-center justify-center w-12 h-12 md:w-14 md:h-14 bg-white border-2 border-black rounded-2xl hover:bg-gray-100 active:scale-95 transition-all">
          <i data-lucide="settings" class="w-6 h-6 text-black"></i>
        </button>
      </div>
    </nav>

    <style is:global>
      /* FORZAR AL RATÓN COHETE A ESTAR POR ENCIMA DE TODO.
        Afecta a cualquier clase o ID que contenga 'mouse-rocket' o 'rocket' del cursor custom.
      */
      .mouse-rocket, 
      [class*="mouse-rocket"], 
      [id*="mouse-rocket"],
      .cursor-rocket {
        z-index: 9999 !important;
        pointer-events: none !important; /* Evita que el propio cohete rompa los clicks de los botones */
        position: fixed !important;
      }
    </style>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        if (window.lucide) {
          window.lucide.createIcons();
        }
      });
    </script>
  </body>
</html>