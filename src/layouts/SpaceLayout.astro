---
import "../styles/global.css";
import bgEspacioDesktop from "../assets/iconos-mapa-espacio/background3space.png";
import SpaceTopBar from "../components/SpaceTopBar.astro";
import SpaceBottomNav from "../components/SpaceBottomNav.astro";

interface Props {
  title: string;
  backHref?: string;
  homeHref?: string;
}

const { title, backHref = "#", homeHref = "/" } = Astro.props;

// CAPA 1 — Estrellas generadas con posiciones, tamaños, retrasos y duraciones
// aleatorias para que titilen de forma asíncrona.
const stars = Array.from({ length: 22 }, () => ({
  top: +(Math.random() * 100).toFixed(2),
  left: +(Math.random() * 100).toFixed(2),
  size: Math.random() > 0.7 ? 2 : 1, // px (w-1 / w-2)
  delay: +(Math.random() * 4).toFixed(2),
  duration: +(2 + Math.random() * 3).toFixed(2),
}));
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Mapa de niveles</title>
  </head>

  <!-- CONTENEDOR PRINCIPAL -->
  <body class="relative min-h-screen w-full overflow-y-auto bg-[#1A0B2E]">
    <!-- CAPA 0: FONDO BASE -->
    <div
      class="fixed inset-0 z-0 bg-cover bg-center bg-no-repeat"
      style={`background-image: url(${bgEspacioDesktop.src});`}
    >
    </div>

    <!-- CAPA 1: EFECTOS ANIMADOS (estrellas titilantes) -->
    <div class="pointer-events-none fixed inset-0 z-10">
      {
        stars.map((s) => (
          <span
            class="star absolute rounded-full bg-white"
            style={`top:${s.top}%;left:${s.left}%;width:${s.size * 4}px;height:${s.size * 4}px;animation-delay:${s.delay}s;animation-duration:${s.duration}s;`}
          />
        ))
      }
    </div>

    <!-- CAPA 2: NAVEGACIÓN SUPERIOR -->
    <SpaceTopBar title={title} backHref={backHref} homeHref={homeHref} />

    <!-- CAPA 3: CONTENIDO PRINCIPAL -->
    <div class="relative z-20 min-h-screen w-full pt-32 md:pt-36 pb-20 md:pb-24">
      <slot />
    </div>

    <!-- BARRA DE NAVEGACIÓN INFERIOR -->
    <SpaceBottomNav />

    <!-- ANIMACIONES PERSONALIZADAS -->
    <style>
      /* Titileo suave y asíncrono de las estrellas */
      @keyframes twinkle {
        0%,
        100% {
          opacity: 0.25;
          transform: scale(0.8);
        }
        50% {
          opacity: 1;
          transform: scale(1.2);
        }
      }

      .star {
        animation-name: twinkle;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
      }
    </style>
  </body>
</html>
