---
// src/components/SectionCard.astro
import Cohete from "../components/cohete1.astro";

interface Section {
  id: string;
  title: string;
  icon: string;
  image: string;
  theme: "astronomia" | "paleontologia" | "biologia";
}

interface Props {
  section: Section;
  index: number; // Añadimos el index para saber si es par o impar
}

const { section, index } = Astro.props;

// Alternar dirección visual en pantallas grandes (Zig-Zag)
const isEven = index % 2 === 0;
const flexDirection = isEven ? "md:flex-row" : "md:flex-row-reverse";

const themeClasses = {
  themeBg: `bg-${section.theme}-themeBg`,
  btnColor: `bg-${section.theme}-btnColor`,
  textColor: `text-${section.theme}-textColor`,
};

// Colores de fallback por si los tokens fallan (puedes ajustar esto a tus variables exactas)
const cardColor = 
  section.theme === 'astronomia' ? 'bg-[#4361EE]' : 
  section.theme === 'paleontologia' ? 'bg-[#c26227]' : 'bg-[#10B981]';
---

<a
  href={`/contenidos/${section.id}`}
  class={`group relative z-10 w-full flex flex-col ${flexDirection} items-center bg-white border-8 border-black rounded-[3rem] md:rounded-[4rem] p-4 md:p-6 shadow-[16px_16px_0_0_#000] hover:-translate-y-4 hover:shadow-[24px_24px_0_0_#000] active:translate-y-2 active:shadow-[8px_8px_0_0_#000] transition-all duration-300 gap-6`}
>
  
  {/* MITAD 1: IMAGEN DEL MUNDO (Ahora ocupa casi el 50% de la cápsula) */}
  <div class={`relative w-full md:w-1/2 aspect-video md:aspect-[4/3] rounded-[2rem] md:rounded-[3rem] border-8 border-black overflow-hidden ${cardColor} shadow-inner flex-shrink-0`}>
    
    <img
      src={section.image}
      alt={section.title || section.theme}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />

    {section.theme === 'astronomia' && (
      <div class="absolute inset-0 flex items-center justify-center transition-transform duration-700 group-hover:scale-110 group-hover:translate-x-4 scale-75 pb-10 pointer-events-none drop-shadow-2xl">
        <Cohete />
      </div>
    )}
  </div>

  {/* MITAD 2: TEXTO Y LLAMADO A LA ACCIÓN */}
  <div class="w-full md:w-1/2 flex flex-col justify-center items-center text-center p-6 md:p-10 space-y-6">
    
    {/* Icono flotante con Lucide */}
    <div class="w-20 h-20 bg-gray-100 rounded-full border-4 border-black shadow-[4px_4px_0_0_#000] flex items-center justify-center -rotate-6 group-hover:rotate-12 transition-transform duration-300">
      <i data-lucide={section.icon} class="w-10 h-10 text-black"></i>
    </div>

    {/* Título de la sección */}
    <h2 class="text-4xl md:text-6xl font-black text-black uppercase tracking-tighter">
      {section.title || section.theme}
    </h2>

    {/* Botón "Explorar" integrado (parece un sticker) */}
    <div class={`mt-4 ${cardColor} border-4 border-black px-8 py-4 rounded-2xl shadow-[6px_6px_0_0_#000] transform transition-transform group-hover:scale-110 group-hover:-rotate-2`}>
      <span class="text-white font-black uppercase tracking-widest text-lg md:text-xl whitespace-nowrap drop-shadow-[0_2px_0_rgba(0,0,0,1)]">
        ¡Explorar Mundo!
      </span>
    </div>

  </div>

  {/* BADGE DE PLAY FLOTANTE (Solo hover) */}
  <div class="absolute -top-6 -right-6 md:top-auto md:-right-8 md:bottom-1/2 bg-[#FFD60A] p-4 rounded-full border-8 border-black opacity-0 scale-50 group-hover:opacity-100 group-hover:scale-100 transition-all duration-300 shadow-[8px_8px_0_0_#000] z-20">
    <i data-lucide="play" class="w-10 h-10 text-black fill-black ml-1"></i>
  </div>
</a>