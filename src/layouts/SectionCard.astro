---
// src/components/SectionCard.astro
interface Section {
  id: string;
  title: string;
  icon: string;
  image: string;
  theme: "astronomia" | "paleontologia" | "biologia";
}

interface Props {
  section: Section;
}

const { section } = Astro.props;

import Cohete from "../components/cohete1.astro";

/**
 * CLASES DINÁMICAS:
 * Construye las clases de Tailwind usando el 'theme' de la sección.
 * Si cambias un color en token.css, se actualizará automáticamente aquí.
 */
const themeClasses = {
  themeBg: `bg-${section.theme}-themeBg`,
  headerBg: `bg-${section.theme}-headerBg`,
  lineColor: `bg-${section.theme}-lineColor`,
  cardBorder: `border-${section.theme}-cardBorder`,
  btnColor: `bg-${section.theme}-btnColor`,
  btnBorder: `border-${section.theme}-btnBorder`,
  textColor: `text-${section.theme}-textColor`,
  btnShadow: `shadow-btn-default shadow-${section.theme}-btnBorder`,
};
---

<!-- TARJETA PRINCIPAL: 
     - hover:-translate-y-2: Efecto de elevación al pasar el mouse.
     - shadow-[12px_12px_0_0_#000]: Sombra sólida estilo Kurzgesagt.
-->
<a
  href={`/seccion/${section.id}`}
  class={`group relative rounded-[3rem] overflow-hidden border-8 border-black shadow-[12px_12px_0_0_#000] ${themeClasses.themeBg} flex flex-col h-[450px] transition-all hover:-translate-y-2 hover:shadow-[20px_20px_0_0_#000] active:translate-y-1 active:shadow-none`}
>
  <div class={`relative h-full overflow-hidden ${themeClasses.themeBg}`}>
    <!-- IMAGEN: object-fit asegura que la imagen cubra el contenedor. group-hover:scale-110 hace zoom al acercar el mouse -->
    <img
      src={section.image}
      alt={section.title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />

    <!-- COMPONENTE FLOTANTE: Solo para astronomía, centrado sobre la imagen -->
    {section.theme === 'astronomia' && (
      <div class="absolute inset-0 flex items-center justify-center transition-transform duration-700 group-hover:scale-110 scale-75 pb-16 pointer-events-none">
        <Cohete />
      </div>
    )}

    <!-- BOTÓN "EXPLORAR": Flota sobre la imagen como un sticker físico. -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 bg-white border-4 border-black px-6 py-3 rounded-2xl shadow-[6px_6px_0_0_#000] transform transition-transform group-hover:scale-110 group-hover:-rotate-2"
    >
      <span
        class="text-black font-black uppercase tracking-widest text-sm whitespace-nowrap"
      >
        ¡Explorar ahora!
      </span>
    </div>

    <!-- ICONO DE PLAY: Aparece solo en hover para indicar interactividad -->
    <div
      class="absolute top-6 right-6 bg-white p-3 rounded-2xl border-4 border-black opacity-0 group-hover:opacity-100 transition-opacity shadow-[4px_4px_0_0_#000]"
    >
      <i data-lucide="play" class="w-6 h-6 text-black fill-black"></i>
    </div>
  </div>
</a>
